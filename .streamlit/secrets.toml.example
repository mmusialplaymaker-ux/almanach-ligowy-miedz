# Skopiuj do .streamlit/secrets.toml (lokalnie) LUB wklej w Streamlit Cloud -> App settings -> Secrets.
# Nie commituj prawdziwego secrets.toml (jest w .gitignore).

APP_PASSWORD = "ustaw-mocne-haslo"   # bramka dostepu (link chroniony haslem)
PM_REGION    = ""                    # opcjonalnie, gdy region nie jest jeszcze w danych

# Tryb danych: domyslnie "csv" (pliki w repo). Dla bazy odkomentuj:
# PM_DATA_MODE = "db"
# PGHOST     = "..."
# PGDATABASE = "..."
# PGUSER     = "..."
# PGPASSWORD = "..."
# PGPORT     = "5432"
